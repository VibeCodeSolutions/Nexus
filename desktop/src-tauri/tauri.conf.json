{
  "productName": "nexus-desktop",
  "version": "0.1.0",
  "identifier": "com.nexus.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "NEXUS Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:7777 http://localhost:7777 http://192.168.0.0/16:7777"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nexus-core"],
    "category": "Productivity",
    "shortDescription": "Personal ADHS-OS",
    "longDescription": "NEXUS hilft dir deine Gedanken, Aufgaben und Projekte zu organisieren."
  }
}
