[Unit]
Description=NEXUS Core Daemon
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/Projekte/Apps/Nexus/core
ExecStart=%h/Projekte/Apps/Nexus/core/target/release/nexus-core
Environment=NEXUS_BIND_ADDR=0.0.0.0:7777
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
